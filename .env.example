# FlowState — example environment. Copy to .env and adjust.

# API
FLOWSTATE_ENV=local
FLOWSTATE_LOG_LEVEL=INFO
FLOWSTATE_API_HOST=0.0.0.0
FLOWSTATE_API_PORT=8000
FLOWSTATE_API_KEY=change-me-local-only

# Model
FLOWSTATE_MODEL_NAME=ag-news-distilbert
FLOWSTATE_MODEL_STAGE=Production
FLOWSTATE_MODEL_PATH=./artifacts/latest/onnx/model_fp16.onnx
FLOWSTATE_TOKENIZER_PATH=./artifacts/latest/model
FLOWSTATE_MAX_SEQ_LEN=128

# Inference runtime (0 = let ONNX Runtime auto-detect thread count)
FLOWSTATE_INTRA_OP_NUM_THREADS=0
FLOWSTATE_INTER_OP_NUM_THREADS=0
FLOWSTATE_WARMUP_ITERATIONS=5

# Batcher
FLOWSTATE_BATCH_MAX_SIZE=32
FLOWSTATE_BATCH_MAX_WAIT_MS=5

# Redis
FLOWSTATE_REDIS_URL=redis://redis:6379/0
FLOWSTATE_CACHE_TTL_SECONDS=600

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio12345

# OTel
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_SERVICE_NAME=flowstate-api
